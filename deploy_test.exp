#!/usr/bin/expect -f
set timeout 120
set password "Mimajiushi666"
set host "root@47.83.211.119"

puts "\n==> Step 1: Cleaning test frontend directory..."
spawn ssh $host "rm -rf /var/www/soas-app-test/*"
expect "*?assword:*" { send "$password\r" }
expect eof

puts "\n==> Step 2: Uploading test frontend files..."
spawn scp -r dist/assets dist/index.html $host:/var/www/soas-app-test/
expect "*?assword:*" { send "$password\r" }
expect eof

puts "\n==> Step 3: Uploading test backend files (server only, no node_modules)..."
spawn bash -c "scp server/index.js server/db.js server/package.json server/package-lock.json server/database.sqlite $host:/var/www/soas-server-test/"
expect "*?assword:*" { send "$password\r" }
expect eof

puts "\n==> Step 4: Installing deps and restarting with PORT=3011..."
spawn ssh $host "cd /var/www/soas-server-test && npm install && pm2 delete soas-test 2>/dev/null; PORT=3011 pm2 start index.js --name soas-test && pm2 save"
expect "*?assword:*" { send "$password\r" }
expect eof

puts "\n==> Deployment to Test Completed!"
